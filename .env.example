# =============================================================================
# Idea di Luce PWA — variabili d'ambiente unificate (root del monorepo)
#
#   cp .env.example .env
#
# Usato da: server (API), client (Next.js), admin (Vite), Prisma, product-hub.
# Su DigitalOcean App Platform puoi incollare lo stesso set in "Environment Variables"
# oppure montare un singolo file .env nella root del deploy.
# =============================================================================

# ——— Runtime server (Express) ———
NODE_ENV=development
PORT=4100
CLIENT_ORIGIN=http://localhost:5273
ADMIN_ORIGIN=http://localhost:5274
ADMIN_SESSION_COOKIE_NAME=admin_sid
ADMIN_SESSION_DAYS=7

# Postgres BFF (docker compose: npm run db:up)
DATABASE_URL=postgresql://ideadiluce:ideadiluce_dev@localhost:5433/ideadiluce?schema=public
# Migrazioni Prisma: stessa URL in locale; su DO usa la connessione diretta (porta 25060).
DIRECT_URL=postgresql://ideadiluce:ideadiluce_dev@localhost:5433/ideadiluce?schema=public
# DigitalOcean (runtime API via PgBouncer, migrate via DIRECT_URL):
# DATABASE_URL=postgresql://USER:PASS@HOST:25061/POOL_NAME?sslmode=require&pgbouncer=true&connection_limit=5
# DIRECT_URL=postgresql://USER:PASS@HOST:25060/defaultdb?sslmode=require

# ——— Odoo / OdooCatalog — catalogo PWA (REST API v2) ———
# "OdooCatalog" = website Odoo (website_id=2, tlb_is_headless) su https://tlbdb.odoo.com
# Contratto: docs/API-Prodotti-Odoo-PWA.md — unica fonte catalogo storefront (lista/dettaglio).
# Auth Bearer + website=ODOO_WEBSITE_ID. Ricerca via indice sync BFF (v2 senza full-text).
ODOO_CATALOG_ENABLED=false
ODOO_CATALOG_BASE_URL=https://tlbdb.odoo.com
ODOO_CATALOG_API_KEY=
ODOO_WEBSITE_ID=2
ODOO_CATALOG_TIMEOUT_MS=25000

# Schema hub (solo redirect URL legacy da import Woo). Opzionale: default DATABASE_URL con schema=hub
HUB_DATABASE_URL=

SESSION_COOKIE_NAME=sid
SESSION_DAYS=30

INTEGRATIONS_TOKEN=
# Usato anche dal plugin WordPress "SEO Migration Exporter" (header X-Integrations-Token)
CHECKOUT_REDIRECT_BASE=

# Social proof scheda prodotto (storico ordini unificato PWA + Odoo, nomi anonimizzati)
SOCIAL_PROOF_ENABLED=true
SOCIAL_PROOF_LOOKBACK_DAYS=30
SOCIAL_PROOF_MAX_EVENTS=12

# Timer carrello: svuota dopo N min dall'ultima modifica righe (allineamento stock Odoo)
CART_RESERVATION_ENABLED=true
CART_RESERVATION_MINUTES=30
# Salta controllo stock su add/patch (solo test API/CI: npm run test:api con staging senza varianti acquistabili)
CART_SKIP_STOCK_CHECK=false

# Cache ISR contenuti CMS (Next.js storefront)
STOREFRONT_URL=http://localhost:3000
REVALIDATE_SECRET=
API_URL=http://localhost:4100
NEXT_PUBLIC_API_URL=http://localhost:4100
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_ODOO_MEDIA_BASE_URL=https://tlbdb.odoo.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_INTEGRATIONS_TOKEN=
# Fallback opzionale lato browser (sconsigliato in produzione)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Legacy Vite shop (deprecato — migrare a NEXT_PUBLIC_* sopra)
VITE_API_URL=http://localhost:4100
VITE_API_BASE_URL=
VITE_STOREFRONT_URL=http://localhost:3000
VITE_ODOO_MEDIA_BASE_URL=https://tlbdb.odoo.com
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_INTEGRATIONS_TOKEN=
# Autocomplete indirizzi checkout (Google ha priorità su Mapbox se entrambi impostati)
# Consigliato: chiavi lato server. Abilita "Places API (New)" sul progetto.
# Credenziali → chiave: Restrizioni API = Places API (New); Restrizioni applicazione = Nessuna (dev) o IP server (NON "Siti web").
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=
# Fallback opzionale lato browser (sconsigliato in produzione)
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPBOX_ACCESS_TOKEN=

# ——— Backoffice admin (Vite :5274) ———
# Precompilati nel form login in sviluppo (solo VITE_* esposti al browser)
VITE_ADMIN_DEV_EMAIL=admin@ideadiluce.local
VITE_ADMIN_DEV_PASSWORD=admin123456
# Utente creato con `npm run db:seed --workspace=server` (vedi ADMIN_SEED_* sotto)
ADMIN_SEED_EMAIL=admin@ideadiluce.local
ADMIN_SEED_PASSWORD=admin123456

# ——— Odoo / OdooCatalog — catalogo PWA (REST API v2) ———
# Contratto: docs/API-Prodotti-Odoo-PWA.md — unica fonte catalogo storefront.
# Auth Bearer + website=ODOO_WEBSITE_ID. Ricerca via indice sync BFF.
ODOO_CATALOG_ENABLED=false
ODOO_CATALOG_BASE_URL=https://tlbdb.odoo.com
ODOO_CATALOG_API_KEY=
ODOO_WEBSITE_ID=2
ODOO_CATALOG_TIMEOUT_MS=25000

# ——— Odoo 18 XML-RPC (ordini, stock, link admin — NON catalogo PWA) ———
# Stessa istanza Odoo (tlbdb.odoo.com). Il catalogo storefront usa ODOO_CATALOG_* sopra.
# ODOO_URL: UI web (es. https://tlbdb.odoo.com/odoo). ODOO_XMLRPC_URL: base senza /odoo.
ODOO_ENABLED=false
ODOO_URL=
ODOO_XMLRPC_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_TIMEOUT_MS=25000
ODOO_CATALOG_LANG=it_IT
# Listini Odoo (product.pricelist id) per segmento B2C/B2B/Professional
ODOO_PRICELIST_B2C_ID=
ODOO_PRICELIST_B2B_ID=
ODOO_PRICELIST_PROFESSIONAL_ID=
ODOO_PRODUCT_DOMAIN=
# ID azione menu Odoo per link prodotto nel BO (default 497)
ODOO_PRODUCT_ACTION_ID=497
ODOO_CATEGORY_DOMAIN=
ODOO_BASE_URL=
ODOO_API_KEY=

# Query consigliate ricerca (import da Odoo — prodotti più acquistati)
SEARCH_HINTS_AUTO_SYNC_ENABLED=true
SEARCH_HINTS_STALE_HOURS=72
SEARCH_HINTS_LOOKBACK_DAYS=90
SEARCH_HINTS_LIMIT=8

# ——— Stripe ———
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# pk_test_… da Dashboard → Developers → API keys (stesso account di STRIPE_SECRET_KEY)
STRIPE_PUBLISHABLE_KEY=

# ——— Spedizioni ———
# @deprecated — sostituito da login backoffice (AdminUser)
ADMIN_API_TOKEN=
SHIPPING_CREDENTIALS_KEY=

# Sede ritiro unico (shipping PICKUP, footer, thank-you)
STORE_PICKUP_LABEL=
STORE_PICKUP_LINE1=Via Appia Pignatelli 450
STORE_PICKUP_POSTAL_CODE=00178
STORE_PICKUP_CITY=Roma
STORE_PICKUP_COUNTRY=IT

DHL_ENABLED=false
DHL_SANDBOX=true
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_API_BASE_URL=
DHL_SHIPPER_POSTAL_CODE=
DHL_SHIPPER_CITY=
DHL_SHIPPER_COUNTRY=

FEDEX_ENABLED=false
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_API_BASE_URL=
FEDEX_SHIPPER_POSTAL_CODE=
FEDEX_SHIPPER_CITY=
FEDEX_SHIPPER_COUNTRY=

# ——— Bonifico ———
BANK_TRANSFER_HOLDER=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BANK_NAME=

# ——— Legacy Nexi / PayPal ———
NEXI_ENABLED=false
NEXI_ENV=sandbox
NEXI_API_KEY=
NEXI_TERMINAL_ID=
NEXI_CHECKOUT_BASE_URL=

PAYPAL_ENABLED=false
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CHECKOUT_BASE_URL=

PUBLIC_SITE_URL=https://shop.ideadiluce.it
APP_PUBLIC_URL=http://localhost:5273
NEXT_PUBLIC_SITE_URL=https://shop.ideadiluce.it

# Search Console — meta tag google-site-verification (opzionale fino al cutover)
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Cookiebot — banner consenso cookie (opzionale; lasciare vuoto in dev locale)
NEXT_PUBLIC_COOKIEBOT_CBID=

# Fase 2 — piattaforma tecnica separata (redirect 301 cross-domain)
TECHNICAL_SITE_URL=
TECHNICAL_ODOO_WEBSITE_ID=

# ——— DeepL (traduzione automatica contenuti sito BO) ———
DEEPL_ENABLED=false
DEEPL_API_KEY=
# Opzionale: https://api-free.deepl.com/v2/translate (free) o https://api.deepl.com/v2/translate (pro)
DEEPL_API_URL=

# ——— Email (reset password) ———
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
PASSWORD_RESET_TOKEN_HOURS=24

# ——— Alert ordini PAID_SYNC_PENDING (Sprint 1) ———
# Minuti dopo paidAt prima di inviare email admin (default 15).
PAID_SYNC_ALERT_MINUTES=15
# Destinatario alert sync Odoo. Se assente: solo log + banner BO.
PAID_SYNC_ALERT_EMAIL=

# ——— DigitalOcean Spaces (upload immagini catalogo dall’admin) ———
# Crea uno Space con CDN; path oggetti: products/{productId}/{uuid}.ext
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_CDN_URL=https://your-space.fra1.cdn.digitaloceanspaces.com
SPACES_REGION=fra1
