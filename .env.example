# =============================================================================
# Idea di Luce PWA — variabili d'ambiente unificate (root del monorepo)
#
#   cp .env.example .env
#
# Usato da: server (API), client (Vite), admin (Vite), Prisma, product-hub.
# Su DigitalOcean App Platform puoi incollare lo stesso set in "Environment Variables"
# oppure montare un singolo file .env nella root del deploy.
# =============================================================================

# ——— Runtime server (Express) ———
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Postgres BFF (docker compose: npm run db:up)
DATABASE_URL=postgresql://ideadiluce:ideadiluce_dev@localhost:5433/ideadiluce?schema=public

# Product Hub — catalogo da import Woo (schema Postgres `hub` sullo stesso host)
HUB_CATALOG_ENABLED=true
# Opzionale: se vuoto, gli script hub usano DATABASE_URL con schema=hub
HUB_DATABASE_URL=

SESSION_COOKIE_NAME=sid
SESSION_DAYS=30

INTEGRATIONS_TOKEN=
CHECKOUT_REDIRECT_BASE=

# ——— Frontend PWA (Vite — prefisso VITE_ obbligatorio) ———
VITE_API_URL=http://localhost:4000
VITE_API_BASE_URL=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_INTEGRATIONS_TOKEN=

# ——— Admin spedizioni (Vite :5174) ———
VITE_ADMIN_TOKEN=

# ——— Odoo 18 XML-RPC ———
ODOO_ENABLED=false
ODOO_URL=
ODOO_XMLRPC_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_TIMEOUT_MS=25000
ODOO_CATALOG_LANG=it_IT
ODOO_PRODUCT_DOMAIN=
ODOO_CATEGORY_DOMAIN=
ODOO_BASE_URL=
ODOO_API_KEY=

# ——— Stripe ———
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ——— Spedizioni ———
ADMIN_API_TOKEN=
SHIPPING_CREDENTIALS_KEY=

DHL_ENABLED=false
DHL_SANDBOX=true
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_API_BASE_URL=
DHL_SHIPPER_POSTAL_CODE=
DHL_SHIPPER_CITY=
DHL_SHIPPER_COUNTRY=

FEDEX_ENABLED=false
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_API_BASE_URL=
FEDEX_SHIPPER_POSTAL_CODE=
FEDEX_SHIPPER_CITY=
FEDEX_SHIPPER_COUNTRY=

# ——— Bonifico ———
BANK_TRANSFER_HOLDER=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BANK_NAME=

# ——— Legacy Nexi / PayPal ———
NEXI_ENABLED=false
NEXI_ENV=sandbox
NEXI_API_KEY=
NEXI_TERMINAL_ID=
NEXI_CHECKOUT_BASE_URL=

PAYPAL_ENABLED=false
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CHECKOUT_BASE_URL=
