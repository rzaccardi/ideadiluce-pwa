generator client {
  provider = "prisma-client-js"
  output   = "../generated/hub-client"
}

datasource db {
  provider = "postgresql"
  url      = env("HUB_DATABASE_URL")
}

enum Locale {
  IT
  EN
  ES
  FR
  DE
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  UNAVAILABLE
}

enum ProductVisibility {
  PUBLIC
  HIDDEN
}

enum ExternalSystem {
  WOOCOMMERCE
  WOOCOMMERCE_VARIATION
  ODOO_TEMPLATE
  ODOO_VARIANT
}

enum TaxonomyKind {
  PRODUCT_CAT
  PWB_BRAND
  PRODUCT_TAG
}

enum MediaKind {
  COVER
  GALLERY
  VARIANT
}

model WooImportRun {
  id         String    @id @default(cuid())
  status     String    @default("running")
  statsJson  Json?
  errorLog   String?   @db.Text
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

model Brand {
  id        String   @id @default(cuid())
  wooTermId Int?     @unique
  code      String   @unique
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Category {
  id         String   @id @default(cuid())
  wooTermId  Int?     @unique
  slug       String   @unique
  name       String
  parentId   String?
  sortOrder  Int      @default(0)
  isRoom     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products ProductCategory[]
}

model Product {
  id              String            @id @default(cuid())
  wooPostId       Int               @unique
  odooTemplateId  Int?              @unique
  slug            String            @unique
  sku             String?
  status          ProductStatus     @default(PUBLISHED)
  visibility      ProductVisibility @default(PUBLIC)
  featured        Boolean           @default(false)
  sortOrder       Int               @default(0)
  brandId         String?
  legacyPermalink String?
  ogImageUrl      String?
  shortDescription String?          @db.Text
  longDescription  String?          @db.Text
  purchasable     Boolean           @default(true)
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  brand      Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  variants   ProductVariant[]
  seo        ProductSEO?
  categories ProductCategory[]
  externalRefs ExternalProductRef[]
  media        ProductMedia[]

  @@index([sku])
  @@index([status])
  @@index([slug])
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  wooPostId     Int     @unique
  odooVariantId Int?    @unique
  slug          String
  sku           String?
  isDefault     Boolean @default(false)
  sortOrder     Int     @default(0)

  product    Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes ProductVariantAttribute[]
  media      ProductMedia[]

  @@index([productId])
  @@index([sku])
}

model ProductVariantAttribute {
  id        String @id @default(cuid())
  variantId String
  name      String
  value     String
  sortOrder Int    @default(0)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, name])
  @@index([variantId])
}

model ProductMedia {
  id              String    @id @default(cuid())
  productId       String
  variantId       String?
  kind            MediaKind @default(GALLERY)
  url             String
  sortOrder       Int       @default(0)
  wooAttachmentId Int?

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductSEO {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  translations ProductSEOTranslation[]
}

model ProductSEOTranslation {
  id              String  @id @default(cuid())
  productSEOId    String
  locale          Locale  @default(IT)
  metaTitle       String?
  metaDescription String? @db.Text
  focusKeyword    String?
  canonical       String?
  noindex         Boolean @default(false)

  productSEO ProductSEO @relation(fields: [productSEOId], references: [id], onDelete: Cascade)

  @@unique([productSEOId, locale])
}

model ExternalProductRef {
  id         String         @id @default(cuid())
  system     ExternalSystem
  externalId String
  productId  String?
  variantId  String?
  metadataJson Json?

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([system, externalId])
  @@index([productId])
}

model UrlRedirect {
  id         String  @id @default(cuid())
  fromPath   String  @unique
  toPath     String
  statusCode Int     @default(301)
  source     String?
}
