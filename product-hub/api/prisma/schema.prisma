generator client {
  provider = "prisma-client-js"
  output   = "../generated/hub-client"
}

datasource db {
  provider = "postgresql"
  url      = env("HUB_DATABASE_URL")
}

model UrlRedirect {
  id         String  @id @default(cuid())
  fromPath   String  @unique
  toPath     String
  statusCode Int     @default(301)
  source     String?
}
