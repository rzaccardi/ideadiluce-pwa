{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@runplay/shared": ["../../runplay/packages/shared/src/index.ts"],
      "@runplay/shared/*": ["../../runplay/packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
