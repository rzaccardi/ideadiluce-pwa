generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING_VERIFICATION
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OdooSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum CheckoutSessionState {
  DRAFT
  COMMITTED
  REDIRECTING
  COMPLETED
  EXPIRED
  FAILED
}

enum CheckoutAttemptStatus {
  STARTED
  SUCCEEDED
  FAILED
}

enum PwaOrderStatus {
  CART_CREATED
  CHECKOUT_STARTED
  PAYMENT_STARTED
  PAYMENT_PENDING
  PAID
  PAYMENT_FAILED
  ABANDONED
  CANCELLED
  CONFIRMED
  COMPLETED
}

enum PwaPaymentStatus {
  NOT_STARTED
  CREATED
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
}

enum PwaPaymentMethod {
  CARD_NEXI
  BANK_TRANSFER
  PAYPAL
  GOOGLE_PAY
  STRIPE
}

enum ShippingMethodType {
  FLAT_RATE
  FREE_SHIPPING
  LIVE_DHL
  LIVE_FEDEX
}

enum CarrierProvider {
  DHL
  FEDEX
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  firstName    String?
  lastName     String?
  phone        String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions         Session[]
  carts            Cart[]
  wishlistItems    WishlistItem[]
  checkoutSessions CheckoutSession[]
  ordersCache      OrderCache[]
  odooMaps         OdooCustomerMap[]
  pwaOrders        PwaOrder[]

  @@index([email])
  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String?
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  carts         Cart[]
  wishlistItems WishlistItem[]
  pwaOrders     PwaOrder[]

  @@index([userId])
  @@index([expiresAt])
}

model OdooCustomerMap {
  id             String         @id @default(cuid())
  userId         String?        @unique
  guestEmail     String?
  odooPartnerId  Int
  syncStatus     OdooSyncStatus @default(PENDING)
  lastSyncAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([guestEmail])
  @@index([odooPartnerId])
}

model Cart {
  id                 String     @id @default(cuid())
  userId             String?
  sessionId          String?
  status             CartStatus @default(ACTIVE)
  currencyCode       String     @default("EUR")
  estimatedSubtotal  Int?
  estimatedTax       Int?
  estimatedShipping  Int?
  estimatedTotal     Int?
  lastPricedAt       DateTime?
  abandonedAt        DateTime?
  convertedOrderId   String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  session  Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  items    CartItem[]
  checkoutSessions CheckoutSession[]
  abandonedEvents  AbandonedCartEvent[]
  pwaOrders PwaOrder[]
  shippingSelection CartShippingSelection?

  @@index([userId])
  @@index([sessionId])
  @@index([status])
}

model CartItem {
  id                        String   @id @default(cuid())
  cartId                    String
  productRef                String
  variantRef                String?
  quantity                  Int      @default(1)
  clientUnitPriceEstimate   Int?
  metadataJson              Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([productRef])
}

model WishlistItem {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  productRef  String
  variantRef  String?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([productRef])
}

model CheckoutSession {
  id                 String                @id @default(cuid())
  cartId             String
  userId             String?
  state              CheckoutSessionState  @default(DRAFT)
  email              String
  billingAddressJson     Json?
  shippingAddressJson    Json?
  shippingMethodRef      String?
  couponCode             String?
  odooPartnerId          Int?
  odooSaleOrderId        Int?
  paymentRedirectUrl     String?
  expiresAt              DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  cart    Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  attempts CheckoutAttempt[]
  pwaOrder PwaOrder?

  @@index([cartId])
  @@index([userId])
  @@index([state])
}

model CheckoutAttempt {
  id                 String                 @id @default(cuid())
  checkoutSessionId  String
  attemptNo          Int
  status             CheckoutAttemptStatus
  provider           String?
  redirectUrl        String?
  failureReason      String?
  rawSnapshotJson    Json?
  createdAt          DateTime               @default(now())

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)

  @@index([checkoutSessionId])
  @@unique([checkoutSessionId, attemptNo])
}

model PwaOrder {
  id                         String            @id @default(cuid())
  cartId                     String
  checkoutSessionId          String?           @unique
  userId                     String?
  sessionId                  String?
  email                      String
  orderStatus                PwaOrderStatus    @default(CART_CREATED)
  paymentStatus              PwaPaymentStatus  @default(NOT_STARTED)
  paymentMethod              PwaPaymentMethod?
  currencyCode               String            @default("EUR")
  amountTotal                Int?
  billingAddressJson         Json?
  shippingAddressJson        Json?
  odooPartnerId              Int?
  odooSaleOrderId            Int?
  providerTransactionId      String?
  lastPaymentError           String?
  checkoutStartedAt          DateTime?
  paymentStartedAt           DateTime?
  paidAt                     DateTime?
  abandonedAt                DateTime?
  cancelledAt                DateTime?
  confirmedAt                DateTime?
  completedAt                DateTime?
  odooLastSyncAt             DateTime?
  odooLastSyncStatus         OdooSyncStatus     @default(PENDING)
  metadataJson               Json?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt

  cart            Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  session         Session?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  payments        PwaPayment[]

  @@index([cartId])
  @@index([userId])
  @@index([sessionId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([odooSaleOrderId])
}

model PwaPayment {
  id                    String            @id @default(cuid())
  orderId               String
  method                PwaPaymentMethod
  status                PwaPaymentStatus  @default(CREATED)
  provider              String
  providerSessionId     String?
  providerTransactionId String?
  amount                Int
  currencyCode          String            @default("EUR")
  redirectUrl           String?
  clientSecret          String?
  instructionsJson      Json?
  failureReason         String?
  rawProviderJson       Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  authorizedAt          DateTime?
  capturedAt            DateTime?
  failedAt              DateTime?
  cancelledAt           DateTime?
  refundedAt            DateTime?

  order PwaOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([provider, providerTransactionId])
}

model OrderCache {
  id               String    @id @default(cuid())
  userId           String?
  odooSaleOrderId  Int
  status           String
  paymentStatus    String?
  currencyCode     String?
  totalAmount      Int?
  snapshotJson     Json?
  syncedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([odooSaleOrderId])
}

model IntegrationLog {
  id                        String    @id @default(cuid())
  service                   String
  operation                 String
  correlationId             String
  requestPayloadRedacted    Json?
  responsePayloadRedacted   Json?
  statusCode                Int?
  success                   Boolean
  startedAt                 DateTime  @default(now())
  finishedAt                DateTime?
  durationMs                Int?
  createdAt                 DateTime  @default(now())

  @@index([correlationId])
  @@index([service, createdAt])
}

model WebhookEvent {
  id                 String    @id @default(cuid())
  source             String
  eventName          String
  externalId         String?
  payloadRedacted    Json?
  processed          Boolean   @default(false)
  processedAt        DateTime?
  result             String?
  createdAt          DateTime  @default(now())

  @@index([processed])
  @@index([source, eventName])
}

model ShippingZone {
  id          String   @id @default(cuid())
  name        String
  countries   String[] // ISO2, es. ["IT","FR"]
  postcodes   String[] // prefissi CAP opzionali
  priority    Int      @default(0)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  methods ShippingMethod[]

  @@index([enabled])
}

model ShippingMethod {
  id              String             @id @default(cuid())
  zoneId          String
  name            String
  type            ShippingMethodType
  enabled         Boolean            @default(true)
  flatAmountCents Int?
  minOrderCents   Int?
  freeAboveCents  Int?
  surchargePct    Float              @default(0)
  priority        Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([type])
}

model CarrierCredential {
  id           String          @id @default(cuid())
  provider     CarrierProvider
  enabled      Boolean         @default(false)
  sandbox      Boolean         @default(true)
  accountId    String?
  apiKey       String?
  apiSecret    String?
  extraJson    Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([provider])
}

model CartShippingSelection {
  id            String   @id @default(cuid())
  cartId        String   @unique
  methodRef     String
  carrierCode   String
  serviceCode   String
  label         String
  amountCents   Int
  currencyCode  String   @default("EUR")
  etaDays       Int?
  rawJson       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model AbandonedCartEvent {
  id          String   @id @default(cuid())
  cartId      String
  eventType   String
  payloadJson Json?
  createdAt   DateTime @default(now())

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([eventType])
}
