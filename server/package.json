{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:nodemon": "nodemon --watch src --ext ts --exec npx tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "node scripts/with-root-env.mjs generate",
    "db:migrate": "node scripts/with-root-env.mjs migrate dev",
    "db:migrate:deploy": "node scripts/with-root-env.mjs migrate deploy",
    "db:push": "node scripts/with-root-env.mjs db push",
    "db:seed": "node scripts/with-root-env.mjs db seed",
    "admin:create-user": "npx tsx scripts/create-admin-user.ts",
    "db:studio": "node scripts/with-root-env.mjs studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tax:db": "npx tsx scripts/tax-matrix-verify.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "codice-fiscale-js": "^2.3.23",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "stripe": "^22.2.0",
    "uuid": "^11.1.0",
    "xmlrpc": "^1.3.2",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/xmlrpc": "^1.3.10",
    "nodemon": "^3.1.9",
    "prisma": "^6.19.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "vitest": "^3.2.6"
  }
}
