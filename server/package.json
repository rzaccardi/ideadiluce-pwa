{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "docker compose -f ../docker-compose.yml up -d --wait && node scripts/free-port.mjs && npx tsx watch src/server.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec npx tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "node scripts/with-root-env.mjs generate",
    "db:migrate": "node scripts/with-root-env.mjs migrate dev",
    "db:migrate:deploy": "node scripts/with-root-env.mjs migrate deploy",
    "db:push": "node scripts/with-root-env.mjs db push",
    "db:seed": "node scripts/with-root-env.mjs db seed",
    "db:studio": "node scripts/with-root-env.mjs studio",
    "sync-odoo": "npx tsx scripts/sync-hub-odoo-mapping.ts"
  },
  "dependencies": {
    "@ideadiluce/hub-api": "*",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "stripe": "^22.2.0",
    "uuid": "^11.1.0",
    "xmlrpc": "^1.3.2",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/xmlrpc": "^1.3.10",
    "nodemon": "^3.1.9",
    "prisma": "^6.19.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3"
  }
}
