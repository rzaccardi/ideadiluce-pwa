# Secret da impostare in DigitalOcean → Apps → ideadiluce-pwa → Settings → Environment
# NON committare valori reali. Copia questo elenco nella UI o usa doctl apps update.
#
# Scope consigliato:
#   api RUN_TIME     → segreti server
#   shop BUILD_TIME  → chiavi pubbliche Stripe (prefisso pk_)
#   admin BUILD_TIME → (nessun secret obbligatorio; VITE_API_URL è nello spec)

# ——— Componente: api ———
ODOO_CATALOG_API_KEY=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SHIPPING_CREDENTIALS_KEY=

# Solo primo deploy / rotazione admin BO (poi rimuovere da BUILD se non serve re-seed)
ADMIN_SEED_EMAIL=admin@ideadiluce.it
ADMIN_SEED_PASSWORD=

# Listini Odoo (product.pricelist id) — se segmentazione B2C/B2B/Professional
# ODOO_PRICELIST_B2C_ID=
# ODOO_PRICELIST_B2B_ID=
# ODOO_PRICELIST_PROFESSIONAL_ID=

# Email transazionali + alert sync Odoo
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# PAID_SYNC_ALERT_EMAIL=ops@ideadiluce.it

# Bonifico bancario (checkout)
# BANK_TRANSFER_HOLDER=
# BANK_TRANSFER_IBAN=
# BANK_TRANSFER_BANK_NAME=

# Opzionali — abilita quando servono
# DEEPL_API_KEY=
# GOOGLE_MAPS_API_KEY=
# MAPBOX_ACCESS_TOKEN=
# DHL_API_KEY=
# DHL_API_SECRET=
# FEDEX_CLIENT_ID=
# FEDEX_CLIENT_SECRET=
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_BUCKET=
# SPACES_CDN_URL=

# ——— Componente: shop (BUILD_TIME) ———
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Opzionale lato server (fallback runtime via GET /api/v1/payments/stripe/config)
STRIPE_PUBLISHABLE_KEY=
